<Window x:Class="AegisSentinel.UI.Views.NativeBridgeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AegisSentinel.UI.Converters"
        Title="AegisSentinel — Privacy Monitor"
        Width="480" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="True">

    <Window.Resources>
        <converters:RiskLevelToBrushConverter x:Key="RiskToBrush"/>
        <converters:SafetyPercentToWidthConverter x:Key="SafetyToWidth"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <!-- Drop shadow container -->
    <Border Margin="8" CornerRadius="12"
            Background="#0F172A"
            Effect="{StaticResource CardShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Title bar -->
                <RowDefinition Height="Auto"/> <!-- Header / score -->
                <RowDefinition Height="*"/>    <!-- Feed list -->
                <RowDefinition Height="40"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ──────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="#0A0F1E"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0" Spacing="8">
                        <TextBlock Text="🛡" FontSize="16"/>
                        <TextBlock FontFamily="{StaticResource MonoFont}"
                                   FontSize="10" FontWeight="Bold"
                                   LetterSpacing="3"
                                   Foreground="#93C5FD"
                                   VerticalAlignment="Center"
                                   Text="AEGISSENTINEL"/>
                        <TextBlock FontSize="9" Foreground="#475569"
                                   VerticalAlignment="Center"
                                   Text="· Privacy Monitor"/>
                    </StackPanel>

                    <!-- Pill: live connection indicator -->
                    <Border Grid.Column="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="10" Padding="8,2"
                            Background="#1E293B">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="ConnectionDot" Color="#10B981"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="ConnectionLabel"
                                       Text="CHROME CONNECTED"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="8" FontWeight="Bold"
                                       LetterSpacing="2"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0" Spacing="4">
                        <Button Content="─" Style="{StaticResource TitleBarButton}"
                                Click="Minimise_Click"/>
                        <Button Content="✕" Style="{StaticResource TitleBarButton}"
                                Foreground="#EF4444" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Latest result hero card ────────────────────────────── -->
            <Border Grid.Row="1" Margin="12,12,12,0"
                    CornerRadius="10" Padding="16"
                    x:Name="HeroCard"
                    Background="#1E293B">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Name="HeroTitle"
                                   Text="Waiting for Privacy Policy…"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E2E8F0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="HeroDomain"
                                   FontSize="10" Foreground="#64748B"
                                   FontFamily="{StaticResource MonoFont}"/>

                        <!-- Score bar -->
                        <Grid Margin="0,6,0,0">
                            <Border Height="6" CornerRadius="3" Background="#0F172A"/>
                            <Border x:Name="ScoreBar" Height="6" CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Width="0">
                                <Border.Background>
                                    <SolidColorBrush x:Name="ScoreBarColor" Color="#475569"/>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Border x:Name="RiskBadge" CornerRadius="4" Padding="6,2">
                                <TextBlock x:Name="RiskBadgeText"
                                           FontSize="9" FontWeight="Bold"
                                           FontFamily="{StaticResource MonoFont}"
                                           LetterSpacing="1.5"/>
                            </Border>
                            <TextBlock x:Name="RetentionText"
                                       FontSize="10" Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Score circle -->
                    <Grid Grid.Column="1" HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Ellipse Width="72" Height="72">
                            <Ellipse.Stroke>
                                <SolidColorBrush x:Name="ScoreCircleColor" Color="#1E293B"/>
                            </Ellipse.Stroke>
                            <Ellipse.StrokeThickness>3</Ellipse.StrokeThickness>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="ScoreNumber" Text="—"
                                       FontSize="22" FontWeight="Black"
                                       HorizontalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush x:Name="ScoreNumberColor" Color="#475569"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="SAFE" FontSize="7" FontWeight="Bold"
                                       FontFamily="{StaticResource MonoFont}"
                                       LetterSpacing="1"
                                       Foreground="#475569"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Feed: history of analysed pages ────────────────────── -->
            <Border Grid.Row="2" Margin="12,8,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="ANALYSIS HISTORY"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9" FontWeight="Bold" LetterSpacing="3"
                               Foreground="#334155" Margin="2,0,0,6"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,8"
                                            Margin="0,0,0,6"
                                            Background="#1E293B"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="HistoryItem_Click"
                                            Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Domain}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#CBD5E1"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding RiskLevel}"
                                                               FontSize="9"
                                                               Foreground="{Binding RiskLevel, Converter={StaticResource RiskToBrush}}"/>
                                                    <TextBlock Text="·" FontSize="9" Foreground="#334155"/>
                                                    <TextBlock Text="{Binding AnalysedAt, StringFormat='HH:mm'}"
                                                               FontSize="9" Foreground="#475569"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Score pill -->
                                            <Border Grid.Column="1" CornerRadius="12"
                                                    Padding="8,3"
                                                    Background="#0F172A"
                                                    VerticalAlignment="Center">
                                                <TextBlock FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding RiskLevel, Converter={StaticResource RiskToBrush}}"
                                                           Text="{Binding SafetyPercent, StringFormat='{}{0}%'}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── Status bar ─────────────────────────────────────────── -->
            <Border Grid.Row="3" CornerRadius="0,0,12,12"
                    Background="#0A0F1E" Padding="14,0">
                <Grid>
                    <TextBlock x:Name="StatusText"
                               Text="Monitoring…"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9" Foreground="#334155"
                               VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9" Foreground="#1E3A5F"
                               VerticalAlignment="Center"
                               Text="v1.0 · AegisSentinel"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
